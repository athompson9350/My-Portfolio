# VPN/LAN friendly defaults for Vite dev server
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
# "true" allows all hosts, or set comma-separated hosts:
# VITE_DEV_ALLOWED_HOSTS=my-vpn-host.local,10.10.0.25
VITE_DEV_ALLOWED_HOSTS=true

VITE_PREVIEW_HOST=0.0.0.0
VITE_PREVIEW_PORT=4173
VITE_PREVIEW_ALLOWED_HOSTS=true
